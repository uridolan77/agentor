{
  "AgentorRuntime": {
    "ServiceName": "Agentor.Api",
    "Version": "0.1.0-rc.1"
  },
  "AgentorPersistence": {
    "Mode": "InMemory"
  },
  "Agentor": {
    "Auth": {
      "Mode": "Fake",
      "AllowFakeOutsideDevelopment": false,
      "HeaderActorIdHeaderName": "X-Agentor-Actor-Id"
    },
    "Integrations": {
      "Athanor": { "Mode": "Fake" },
      "Conexus": { "Mode": "Fake" },
      "Mcp": { "Mode": "Fake" },
      "ExternalAgents": { "Mode": "Fake" }
    },
    "RuntimePolicy": {
      "AllowedToolKeys": [],
      "DeniedToolKeys": [],
      "MaxAutoApproveRisk": "High"
    },
    "ToolExecution": {
      "TimeoutMilliseconds": 60000,
      "MaxAttempts": 3,
      "RetryDelayMilliseconds": 0
    },
    "RunQueue": {
      "ExecutionMode": "Inline"
    },
    "Outbox": {
      "MaxDispatchAttempts": 5
    },
    "TransportResilience": {
      "Enabled": true,
      "MaxRetries": 2,
      "BaseBackoffMilliseconds": 10,
      "CircuitFailureThreshold": 5,
      "CircuitOpenDurationSeconds": 30
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
