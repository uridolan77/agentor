{
  "AgentorRuntime": {
    "ServiceName": "Agentor.Api",
    "Version": "0.1.0-rc.1"
  },
  "AgentorPersistence": {
    "Mode": "InMemory"
  },
  "Agentor": {
    "RuntimePolicy": {
      "AllowedToolKeys": [],
      "DeniedToolKeys": [],
      "MaxAutoApproveRisk": "High"
    },
    "ToolExecution": {
      "TimeoutMilliseconds": 60000,
      "MaxAttempts": 3,
      "RetryDelayMilliseconds": 0
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
